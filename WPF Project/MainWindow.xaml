<Window x:Class="WPF_Project.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Project"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" Height="242" VerticalAlignment="Center" Width="282">
            <Label Content="Select the operation" HorizontalAlignment="Center" Width="130"/>
            <ComboBox x:Name="combo" Width="120" HorizontalAlignment="Center">
                <ComboBoxItem Content="Plus"/>
                <ComboBoxItem Content="Minus"/>
                <ComboBoxItem Content="Multiplication"/>
                <ComboBoxItem Content="Division"/>
            </ComboBox>
            <Label Content="Number 1" HorizontalAlignment="Center" Width="130"/>
            <TextBox x:Name="text1" TextWrapping="Wrap" Width="120"/>
            <Label Content="Number2" HorizontalAlignment="Center" Width="130"/>
            <TextBox x:Name="text2" TextWrapping="Wrap" Width="120"/>
            <Button x:Name="Button" Content="Button" Height="40" HorizontalAlignment="Center" Width="150" Margin="0,20,0,0" Click="Button_Click"/>
        </StackPanel>
        <Label Content="Calculator" HorizontalAlignment="Left" Margin="340,69,0,0" VerticalAlignment="Top"/>
        <Label x:Name="rezult" Content="The rezult is" HorizontalAlignment="Center" Margin="0,343,0,0" VerticalAlignment="Top" Width="154"/>

    </Grid>
</Window>
